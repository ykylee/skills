#!/usr/bin/env python3
"""skill-lint: 카탈로그 SKILL.md 의 frontmatter / 본문 정합성 검증.

본 스크립트는 카탈로그-특유 rule 만 담당한다:
  E001: frontmatter YAML 파싱 실패
  E002: 표준 YAML 파서 비호환 (mini-parser 는 통과하지만 값이 조용히 망가지는 구조)
  E010: required key 누락 (name, description)
  E020: name 형식 위반 또는 디렉터리명 불일치
  E030: description 1-line / ≤ 200자
  E040: metadata.claude_code.harness_compat 누락 또는 비어있음
  E200: 깨진 내부 링크
  W100: 본문 단락 (When to use, Procedure) 누락
  W110: 미사용 references/, assets/, scripts/ 디렉터리

일반 markdown rule (line-length, duplicate heading 등) 은 markdownlint-cli2 가,
외부 링크 (http/https) 는 lychee 가 담당한다.

Usage:
    python3 scripts/skill-lint [--path skills] [--strict] [--json]
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path

from _frontmatter import check_yaml_strict, parse_frontmatter

# 카탈로그-특유 상수
NAME_RE = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
DESCRIPTION_MAX = 200
REQUIRED_KEYS = ("name", "description")
REQUIRED_SECTIONS = ("## When to use", "## Procedure")
UNUSED_DIRS = ("references", "assets", "scripts")
SEVERITY_E = "E"
SEVERITY_W = "W"


def parse_frontmatter_unused(text: str) -> None:
    """DEPRECATED: parse_frontmatter 는 _frontmatter 모듈에서 import 함 (top of file).

    본 함수는 module-level 의 *inline 정의 자리표시자* 일 뿐, 호출되지 않는다.
    """


def _strip_inline_link_target(link: str) -> tuple[str, str]:
    """markdown 링크 `(text)` 에서 path 와 title 을 분리. 단순 파싱."""
    title = ""
    path = link
    # `<...>` 제거 (이미 raw 텍스트로 들어오므로 보통 없음)
    if link.startswith("<") and link.endswith(">"):
        path = link[1:-1].strip()
    # `(<path> "<title>")` 분리 시도
    m = re.match(r'^(\S+)(\s+"[^"]*")?$', link.strip())
    if m:
        path = m.group(1)
        if m.group(2):
            title = m.group(2).strip()
    return path, title


def check_file(path: Path, repo_root: Path, strict: bool) -> list[dict]:
    text = path.read_text(encoding="utf-8")
    rel = str(path.relative_to(repo_root))

    if not text.startswith("---"):
        return [{
            "file": rel,
            "line": 0,
            "rule": "E001",
            "message": "frontmatter 시작 마커 (---) 없음",
        }]

    fm, parse_errors = parse_frontmatter(text)
    violations: list[dict] = [
        {"file": rel, "line": 0, "rule": c, "message": m}
        for c, _, m in parse_errors
    ]

    # E002: mini-parser 는 관대하므로, 표준 YAML 파서가 거부하는 구조를 따로 검사한다.
    violations.extend(
        {"file": rel, "line": ln, "rule": c, "message": m}
        for c, ln, m in check_yaml_strict(text)
    )
    if fm is None:
        return violations

    end = text.find("\n---", 3)
    body = text[end + 4:] if end != -1 else ""

    # E010: required keys
    for k in REQUIRED_KEYS:
        if k not in fm:
            violations.append({
                "file": rel, "line": 0, "rule": "E010",
                "message": f"required key 누락: {k}",
            })

    name = fm.get("name", "") or ""
    # E020: name 형식 + 디렉터리 일치
    if not isinstance(name, str) or not NAME_RE.match(name):
        violations.append({
            "file": rel, "line": 0, "rule": "E020",
            "message": (
                f"name 형식 위반: `{name!r}` "
                f"(regex: ^[a-z0-9]+(-[a-z0-9]+)*$)"
            ),
        })
    else:
        dir_name = path.parent.name
        if name != dir_name:
            violations.append({
                "file": rel, "line": 0, "rule": "E020",
                "message": f"name ≠ 디렉터리명: name=`{name}` dir=`{dir_name}`",
            })

    # E030: description 검사
    desc = fm.get("description", "")
    if not isinstance(desc, str):
        violations.append({
            "file": rel, "line": 0, "rule": "E030",
            "message": "description 누락 또는 잘못된 타입",
        })
    else:
        if "\n" in desc:
            violations.append({
                "file": rel, "line": 0, "rule": "E030",
                "message": "description 1-line 이어야 함",
            })
        elif len(desc) > DESCRIPTION_MAX:
            violations.append({
                "file": rel, "line": 0, "rule": "E030",
                "message": (
                    f"description 길이 > {DESCRIPTION_MAX}자 ({len(desc)}자)"
                ),
            })

    # E040: harness_compat (nested under metadata.claude_code per hybrid policy)
    meta = fm.get("metadata", {})
    if not isinstance(meta, dict):
        meta = {}
    cc = meta.get("claude_code", {})
    if not isinstance(cc, dict):
        cc = {}
    hc = cc.get("harness_compat", [])
    if not isinstance(hc, list) or len(hc) == 0:
        violations.append({
            "file": rel, "line": 0, "rule": "E040",
            "message": "metadata.claude_code.harness_compat 누락 또는 비어있음",
        })

    # E200: 깨진 내부 링크
    for m in re.finditer(r"\]\(([^)\s]+)(?:\s+\"[^\"]*\")?\)", body):
        link = m.group(1).strip()
        # 외부 / mailto / anchor-only skip
        if (
            link.startswith(("http://", "https://", "mailto:", "ftp://"))
            or link.startswith("#")
        ):
            continue
        # `<...>` 래핑 제거
        if link.startswith("<") and link.endswith(">"):
            link = link[1:-1]
        # path#anchor 분리
        file_part = link.split("#", 1)[0]
        if not file_part:
            continue
        target = (path.parent / file_part).resolve()
        if not target.exists():
            violations.append({
                "file": rel, "line": 0, "rule": "E200",
                "message": f"깨진 내부 링크: `{link}`",
            })

    # W100: 본문 단락
    for sec in REQUIRED_SECTIONS:
        if sec not in body:
            violations.append({
                "file": rel, "line": 0, "rule": "W100",
                "message": f"본문 단락 누락: {sec}",
            })

    # W110: 미사용 references/, assets/, scripts/
    for sub in UNUSED_DIRS:
        sub_path = path.parent / sub
        if sub_path.is_dir():
            used = False
            for line in body.split("\n"):
                if f"/{sub}/" in line or f"/{sub} " in line or line.endswith(f"/{sub}"):
                    used = True
                    break
            if not used:
                violations.append({
                    "file": rel, "line": 0, "rule": "W110",
                    "message": f"미사용 디렉터리: {sub}/",
                })

    return violations


def main() -> int:
    parser = argparse.ArgumentParser(
        description="카탈로그 SKILL.md frontmatter / 본문 검증."
    )
    parser.add_argument("--path", default="skills",
                        help="스킬 루트 (default: skills)")
    parser.add_argument("--strict", action="store_true",
                        help="W 코드도 에러로 처리")
    parser.add_argument("--json", action="store_true",
                        help="JSON 출력")
    args = parser.parse_args()

    root = Path(args.path).resolve()
    if not root.exists():
        print(f"error: {root} 없음", file=sys.stderr)
        return 2
    if not root.is_dir():
        print(f"error: {root} 가 디렉터리가 아님", file=sys.stderr)
        return 2

    files = sorted(root.glob("*/SKILL.md"))
    if not files:
        print(f"info: {root} 아래 SKILL.md 없음", file=sys.stderr)
        return 0

    repo_root = Path.cwd().resolve()
    all_violations: list[dict] = []
    for f in files:
        all_violations.extend(check_file(f, repo_root, strict=args.strict))

    if args.json:
        print(json.dumps(
            {"violations": all_violations, "checked": len(files)},
            indent=2, ensure_ascii=False,
        ))
    else:
        if not all_violations:
            print(f"[skill-lint] {len(files)} SKILL.md, clean.")
        else:
            print(f"[skill-lint] {len(files)} SKILL.md, "
                  f"{len(all_violations)} violations:")
            for v in all_violations:
                print(f"  {v['file']}:{v['line']} {v['rule']} {v['message']}")

    exit_code = 0
    for v in all_violations:
        if v["rule"].startswith(SEVERITY_E):
            exit_code = 1
        if args.strict and v["rule"].startswith(SEVERITY_W):
            exit_code = 1
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
