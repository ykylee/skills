#!/usr/bin/env python3
"""skill-lint: 카탈로그 SKILL.md 의 frontmatter / 본문 정합성 검증.

본 스크립트는 카탈로그-특유 rule 만 담당한다:
  E001: frontmatter YAML 파싱 실패
  E010: required key 누락 (name, description)
  E020: name 형식 위반 또는 디렉터리명 불일치
  E030: description 1-line / ≤ 200자
  E040: metadata.harness_compat 누락 또는 비어있음
  E200: 깨진 내부 링크
  W100: 본문 단락 (When to use, Procedure) 누락
  W110: 미사용 references/, assets/, scripts/ 디렉터리

일반 markdown rule (line-length, duplicate heading 등) 은 markdownlint-cli2 가,
외부 링크 (http/https) 는 lychee 가 담당한다.

Usage:
    python3 scripts/skill-lint [--path skills] [--strict] [--json]
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path

# 카탈로그-특유 상수
NAME_RE = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
DESCRIPTION_MAX = 200
REQUIRED_KEYS = ("name", "description")
REQUIRED_SECTIONS = ("## When to use", "## Procedure")
UNUSED_DIRS = ("references", "assets", "scripts")
SEVERITY_E = "E"
SEVERITY_W = "W"


def parse_frontmatter(text: str) -> tuple[dict | None, list[tuple]]:
    """간단한 YAML frontmatter 파서 (key:value, 1-depth list, 1-depth nested).

    정밀한 YAML 파서는 의도적으로 사용하지 않는다 — 카탈로그 frontmatter 가
    단순한 구조(key:value + 1-depth list + 1-depth nested) 라는 가정.
    """
    if not text.startswith("---"):
        return None, [("E001", 0, "frontmatter 시작 마커 (---) 없음")]
    end = text.find("\n---", 3)
    if end == -1:
        return None, [("E001", 0, "frontmatter 종료 마커 (---) 없음")]

    raw = text[3:end].strip("\n")
    fm: dict = {}
    errors: list[tuple] = []
    lines = raw.split("\n")
    i = 0

    while i < len(lines):
        line = lines[i]
        s = line.strip()
        if not s or s.startswith("#"):
            i += 1
            continue
        if ":" not in line:
            errors.append(("E001", 0, f"YAML 파싱 실패: `{s}`"))
            i += 1
            continue
        key, _, rest = line.partition(":")
        key = key.strip()
        rest = rest.strip()

        # rest 가 비어있으면 다음 줄의 형태로 list / nested / 빈 값 결정
        if not rest:
            # (a) list: 다음 줄이 `  - ...`
            if i + 1 < len(lines) and re.match(r"^\s+-\s+", lines[i + 1]):
                items: list = []
                j = i + 1
                while j < len(lines) and re.match(r"^\s+-\s+", lines[j]):
                    items.append(lines[j].strip()[2:].strip().strip('"').strip("'"))
                    j += 1
                fm[key] = items
                i = j
                continue
            # (b) 1-depth nested: 다음 줄이 `  key: ...` 또는 `  key:` + 자식 list
            if i + 1 < len(lines) and re.match(r"^\s+\S", lines[i + 1]) and ":" in lines[i + 1]:
                nested: dict = {}
                j = i + 1
                while j < len(lines) and re.match(r"^\s+\S", lines[j]) and ":" in lines[j]:
                    sub = lines[j].strip()
                    sk, _, sv = sub.partition(":")
                    sv = sv.strip()
                    if not sv:
                        # 자식이 `- ...` 형태의 list 인지 확인
                        sub_items: list = []
                        k2 = j + 1
                        while k2 < len(lines) and re.match(r"^\s+-\s+", lines[k2]):
                            sub_items.append(lines[k2].strip()[2:].strip().strip('"').strip("'"))
                            k2 += 1
                        if sub_items:
                            nested[sk.strip()] = sub_items
                            j = k2
                            continue
                        nested[sk.strip()] = ""
                    elif sv.startswith("[") and sv.endswith("]"):
                        inner = sv[1:-1].strip()
                        nested[sk.strip()] = [
                            x.strip().strip('"').strip("'")
                            for x in inner.split(",")
                            if x.strip()
                        ]
                    else:
                        nested[sk.strip()] = sv.strip('"').strip("'")
                    j += 1
                if nested:
                    fm[key] = nested
                    i = j
                    continue
            # (c) 빈 값
            fm[key] = ""
            i += 1
            continue

        # inline list `[a, b]`
        if rest.startswith("[") and rest.endswith("]"):
            inner = rest[1:-1].strip()
            items = []
            if inner:
                items = [
                    x.strip().strip('"').strip("'")
                    for x in inner.split(",")
                    if x.strip()
                ]
            fm[key] = items
            i += 1
            continue

        # 그 외: scalar
        fm[key] = rest.strip('"').strip("'")
        i += 1

    return fm, errors


def _strip_inline_link_target(link: str) -> tuple[str, str]:
    """markdown 링크 `(text)` 에서 path 와 title 을 분리. 단순 파싱."""
    title = ""
    path = link
    # `<...>` 제거 (이미 raw 텍스트로 들어오므로 보통 없음)
    if link.startswith("<") and link.endswith(">"):
        path = link[1:-1].strip()
    # `(<path> "<title>")` 분리 시도
    m = re.match(r'^(\S+)(\s+"[^"]*")?$', link.strip())
    if m:
        path = m.group(1)
        if m.group(2):
            title = m.group(2).strip()
    return path, title


def check_file(path: Path, repo_root: Path, strict: bool) -> list[dict]:
    text = path.read_text(encoding="utf-8")
    rel = str(path.relative_to(repo_root))

    if not text.startswith("---"):
        return [{
            "file": rel,
            "line": 0,
            "rule": "E001",
            "message": "frontmatter 시작 마커 (---) 없음",
        }]

    fm, parse_errors = parse_frontmatter(text)
    violations: list[dict] = [
        {"file": rel, "line": 0, "rule": c, "message": m}
        for c, _, m in parse_errors
    ]
    if fm is None:
        return violations

    end = text.find("\n---", 3)
    body = text[end + 4:] if end != -1 else ""

    # E010: required keys
    for k in REQUIRED_KEYS:
        if k not in fm:
            violations.append({
                "file": rel, "line": 0, "rule": "E010",
                "message": f"required key 누락: {k}",
            })

    name = fm.get("name", "") or ""
    # E020: name 형식 + 디렉터리 일치
    if not isinstance(name, str) or not NAME_RE.match(name):
        violations.append({
            "file": rel, "line": 0, "rule": "E020",
            "message": (
                f"name 형식 위반: `{name!r}` "
                f"(regex: ^[a-z0-9]+(-[a-z0-9]+)*$)"
            ),
        })
    else:
        dir_name = path.parent.name
        if name != dir_name:
            violations.append({
                "file": rel, "line": 0, "rule": "E020",
                "message": f"name ≠ 디렉터리명: name=`{name}` dir=`{dir_name}`",
            })

    # E030: description 검사
    desc = fm.get("description", "")
    if not isinstance(desc, str):
        violations.append({
            "file": rel, "line": 0, "rule": "E030",
            "message": "description 누락 또는 잘못된 타입",
        })
    else:
        if "\n" in desc:
            violations.append({
                "file": rel, "line": 0, "rule": "E030",
                "message": "description 1-line 이어야 함",
            })
        elif len(desc) > DESCRIPTION_MAX:
            violations.append({
                "file": rel, "line": 0, "rule": "E030",
                "message": (
                    f"description 길이 > {DESCRIPTION_MAX}자 ({len(desc)}자)"
                ),
            })

    # E040: harness_compat
    meta = fm.get("metadata", {})
    if not isinstance(meta, dict):
        meta = {}
    hc = meta.get("harness_compat", [])
    if not isinstance(hc, list) or len(hc) == 0:
        violations.append({
            "file": rel, "line": 0, "rule": "E040",
            "message": "metadata.harness_compat 누락 또는 비어있음",
        })

    # E200: 깨진 내부 링크
    for m in re.finditer(r"\]\(([^)\s]+)(?:\s+\"[^\"]*\")?\)", body):
        link = m.group(1).strip()
        # 외부 / mailto / anchor-only skip
        if (
            link.startswith(("http://", "https://", "mailto:", "ftp://"))
            or link.startswith("#")
        ):
            continue
        # `<...>` 래핑 제거
        if link.startswith("<") and link.endswith(">"):
            link = link[1:-1]
        # path#anchor 분리
        file_part = link.split("#", 1)[0]
        if not file_part:
            continue
        target = (path.parent / file_part).resolve()
        if not target.exists():
            violations.append({
                "file": rel, "line": 0, "rule": "E200",
                "message": f"깨진 내부 링크: `{link}`",
            })

    # W100: 본문 단락
    for sec in REQUIRED_SECTIONS:
        if sec not in body:
            violations.append({
                "file": rel, "line": 0, "rule": "W100",
                "message": f"본문 단락 누락: {sec}",
            })

    # W110: 미사용 references/, assets/, scripts/
    for sub in UNUSED_DIRS:
        sub_path = path.parent / sub
        if sub_path.is_dir():
            used = False
            for line in body.split("\n"):
                if f"/{sub}/" in line or f"/{sub} " in line or line.endswith(f"/{sub}"):
                    used = True
                    break
            if not used:
                violations.append({
                    "file": rel, "line": 0, "rule": "W110",
                    "message": f"미사용 디렉터리: {sub}/",
                })

    return violations


def main() -> int:
    parser = argparse.ArgumentParser(
        description="카탈로그 SKILL.md frontmatter / 본문 검증."
    )
    parser.add_argument("--path", default="skills",
                        help="스킬 루트 (default: skills)")
    parser.add_argument("--strict", action="store_true",
                        help="W 코드도 에러로 처리")
    parser.add_argument("--json", action="store_true",
                        help="JSON 출력")
    args = parser.parse_args()

    root = Path(args.path).resolve()
    if not root.exists():
        print(f"error: {root} 없음", file=sys.stderr)
        return 2
    if not root.is_dir():
        print(f"error: {root} 가 디렉터리가 아님", file=sys.stderr)
        return 2

    files = sorted(root.glob("*/SKILL.md"))
    if not files:
        print(f"info: {root} 아래 SKILL.md 없음", file=sys.stderr)
        return 0

    repo_root = Path.cwd().resolve()
    all_violations: list[dict] = []
    for f in files:
        all_violations.extend(check_file(f, repo_root, strict=args.strict))

    if args.json:
        print(json.dumps(
            {"violations": all_violations, "checked": len(files)},
            indent=2, ensure_ascii=False,
        ))
    else:
        if not all_violations:
            print(f"[skill-lint] {len(files)} SKILL.md, clean.")
        else:
            print(f"[skill-lint] {len(files)} SKILL.md, "
                  f"{len(all_violations)} violations:")
            for v in all_violations:
                print(f"  {v['file']}:{v['line']} {v['rule']} {v['message']}")

    exit_code = 0
    for v in all_violations:
        if v["rule"].startswith(SEVERITY_E):
            exit_code = 1
        if args.strict and v["rule"].startswith(SEVERITY_W):
            exit_code = 1
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
